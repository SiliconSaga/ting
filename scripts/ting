#!/usr/bin/env bash
# scripts/ting — invoke the ting CLI from the project root.
set -euo pipefail

here="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
root="$(cd -- "$here/.." && pwd)"

if [[ -d "$root/.venv" ]]; then
    # shellcheck disable=SC1091
    source "$root/.venv/bin/activate"
fi

cd "$root"
exec python -m ting.cli "$@"
